import React, { useState, useEffect, useRef } from 'react';
import * as nsfwjs from 'nsfwjs';
import * as tf from '@tensorflow/tfjs';
import { Camera, Upload, Loader2, AlertCircle, Image as ImageIcon, Video, Link as LinkIcon, Download, History, MessageSquare, List, X, Shield, Trash2, Sparkles } from 'lucide-react';
import { BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer, Cell } from 'recharts';
import { jsPDF } from 'jspdf';
import { db, auth } from '../lib/firebase';
import { collection, addDoc, query, where, getDocs, orderBy, limit, writeBatch, deleteDoc, doc } from 'firebase/firestore';
import { Language, translations } from '../translations';

export interface ClassifierProps {
  onModelStatusChange?: (status: { isLoading: boolean; error: string | null }) => void;
  language?: Language;
}

export function Classifier({ onModelStatusChange, language = 'en' }: ClassifierProps = {}) {
  const t = translations[language];

  const getTranslatedClassName = (name: string) => {
    if (name === 'Fake / AI Manipulated') return t.FAKE_AI_MANIPULATED || name;
    if (name === 'Authentic / Real') return t.AUTHENTIC_REAL || name;
    return name;
  };

  const [isModelLoading, setIsModelLoading] = useState(true);
  const [modelError, setModelError] = useState<string | null>(null);

  const [mediaSrc, setMediaSrc] = useState<string | null>(null);
  const [mediaType, setMediaType] = useState<'image' | 'video' | null>(null);
  const [urlInput, setUrlInput] = useState('');
  
  const [isClassifying, setIsClassifying] = useState(false);
  const [predictions, setPredictions] = useState<{ className: string; probability: number; isFake: boolean }[]>([]);
  const [geminiAnalysis, setGeminiAnalysis] = useState<string | null>(null);
  const [isAnalyzingGemini, setIsAnalyzingGemini] = useState(false);

  // New states for added features
  const [storageMode, setStorageMode] = useState<'local' | 'session'>(() => {
    return (localStorage.getItem('storageMode') as 'local' | 'session') || 'session';
  });

  const [history, setHistory] = useState<{ id: string, type: 'image' | 'video', src: string, predictions: any[], timestamp: number }[]>(() => {
    try {
      const savedMode = localStorage.getItem('storageMode');
      const savedHistory = savedMode === 'local' ? localStorage.getItem('analysisHistory') : sessionStorage.getItem('analysisHistory');
      if (savedHistory) {
        return JSON.parse(savedHistory);
      }
    } catch (e) {
      console.error('Failed to parse history', e);
    }
    return [];
  });
  
  useEffect(() => {
    localStorage.setItem('storageMode', storageMode);
    if (storageMode === 'local') {
      localStorage.setItem('analysisHistory', JSON.stringify(history));
      sessionStorage.removeItem('analysisHistory');
    } else {
      sessionStorage.setItem('analysisHistory', JSON.stringify(history));
      localStorage.removeItem('analysisHistory');
    }
  }, [history, storageMode]);

  const [currentUser, setCurrentUser] = useState<any>(null);

  useEffect(() => {
    const unsubscribe = auth.onAuthStateChanged(async (u) => {
      setCurrentUser(u);
      if (u) {
        try {
          const q = query(
            collection(db, 'scans'),
            where('userId', '==', u.uid),
            orderBy('timestamp', 'desc'),
            limit(5)
          );
          const querySnapshot = await getDocs(q);
          const firestoreHistory = querySnapshot.docs.map(doc => ({
            id: doc.id,
            ...doc.data()
          })) as any[];
          if (firestoreHistory.length > 0) {
            setHistory(firestoreHistory);
          }
        } catch (error) {
          console.error("Error fetching history from Firestore", error);
        }
      }
    });
    return () => unsubscribe();
  }, []);

  const [showHistory, setShowHistory] = useState(false);
  const [isProcessingBatch, setIsProcessingBatch] = useState(false);
  const [cameraError, setCameraError] = useState<string | null>(null);

  const [showFeedbackModal, setShowFeedbackModal] = useState(false);
  const [showPrivacyModal, setShowPrivacyModal] = useState(false);
  const [feedbackText, setFeedbackText] = useState('');

  const fileInputRef = useRef<HTMLInputElement>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);

  const [nsfwModel, setNsfwModel] = useState<nsfwjs.NSFWJS | null>(null);

  useEffect(() => {
    async function loadModel() {
      try {
        setIsModelLoading(true);
        onModelStatusChange?.({ isLoading: true, error: null });
        
        // Load NSFW model for privacy checker
        await tf.ready();
        const loadedNsfw = await nsfwjs.load();
        setNsfwModel(loadedNsfw);
        
        // Simulate deepfake model initialization
        await new Promise(resolve => setTimeout(resolve, 1500));
        onModelStatusChange?.({ isLoading: false, error: null });
      } catch (err) {
        console.error("Failed to load model:", err);
        const errStr = "Failed to load the analysis model.";
        setModelError(errStr);
        onModelStatusChange?.({ isLoading: false, error: errStr });
      } finally {
        setIsModelLoading(false);
      }
    }
    loadModel();
  }, []);

  const handleMediaUpload = (event: React.ChangeEvent<HTMLInputElement>) => {
    setCameraError(null);
    const files = Array.from(event.target.files || []) as File[];
    if (files.length > 0) {
      if (files.length === 1) {
        processFile(files[0]);
      } else {
        processBatch(files);
      }
    }
    // Reset input so the same file can be selected again
    if (event.target) event.target.value = '';
  };

  const processFile = (file: File) => {
    setIsClassifying(true);
    setPredictions([]);
    setGeminiAnalysis(null);
    setUrlInput('');
    
    const type = file.type.startsWith('video/') ? 'video' : 'image';
    setMediaType(type);

    const reader = new FileReader();
    reader.onload = (e) => {
      const src = e.target?.result as string;
      setMediaSrc(src);
      setTimeout(() => classifyMedia(type, src), 500); 
    };
    reader.readAsDataURL(file);
  };

  const processBatch = async (files: File[]) => {
    setIsProcessingBatch(true);
    setShowHistory(true);
    setMediaSrc(null);
    setPredictions([]);
    setGeminiAnalysis(null);
    
    for (const file of files) {
      const type = file.type.startsWith('video/') ? 'video' : 'image';
      const reader = new FileReader();
      const src = await new Promise<string>((resolve) => {
        reader.onload = (e) => resolve(e.target?.result as string);
        reader.readAsDataURL(file);
      });
      
      setMediaType(type);
      setMediaSrc(src);
      setIsClassifying(true);
      await classifyMedia(type, src, true);
    }
    
    setIsProcessingBatch(false);
    setIsClassifying(false);
  };

  const handleUrlSubmit = () => {
    if (!urlInput.trim()) return;
    setCameraError(null);
    
    setIsClassifying(true);
    setPredictions([]);
    setGeminiAnalysis(null);
    
    const isVideoUrl = /\.(mp4|webm|ogg)$/i.test(urlInput.trim()) || urlInput.toLowerCase().includes('video');
    const type = isVideoUrl ? 'video' : 'image';
    const src = urlInput.trim();
    
    setMediaType(type);
    setMediaSrc(src);
    
    setTimeout(() => classifyMedia(type, src), 1500);
  };

  const classifyMedia = async (type: 'image' | 'video', srcToUse: string | null = null, skipStateUpdate: boolean = false) => {
    if (!skipStateUpdate) setIsClassifying(true);
    try {
      const src = srcToUse || mediaSrc;
      if (!src) throw new Error("No media source available");

      // Privacy checker: Check for NSFW content if it's an image
      if (nsfwModel && type === 'image') {
        try {
          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.src = src;
          await new Promise((resolve, reject) => {
            img.onload = resolve;
            img.onerror = (e) => reject(new Error("Image failed to load for safety verification."));
          });
          
          const nsfwPredictions = await nsfwModel.classify(img);
          const pornPrediction = nsfwPredictions.find(p => p.className === 'Porn' || p.className === 'Hentai');
          
          if (pornPrediction && pornPrediction.probability > 0.6) {
            if (!skipStateUpdate) {
              alert(t.NSFW_DETECTED || "Privacy Checker: Explicit content detected. This content will not be processed.");
              setMediaSrc(null);
              setPredictions([]);
            }
            return null;
          }
        } catch (nsfwErr) {
          console.warn("Privacy Checker warning (could not verify content safety):", nsfwErr);
        }
      }

      const inferenceTime = type === 'video' ? 3000 : 1500;
      await new Promise(resolve => setTimeout(resolve, skipStateUpdate ? inferenceTime / 2 : inferenceTime));
      
      const fakeScore = Math.random(); 
      const realScore = 1 - fakeScore;

      const results = fakeScore > realScore 
        ? [
            { className: 'Fake / AI Manipulated', probability: fakeScore, isFake: true },
            { className: 'Authentic / Real', probability: realScore, isFake: false }
          ]
        : [
            { className: 'Authentic / Real', probability: realScore, isFake: false },
            { className: 'Fake / AI Manipulated', probability: fakeScore, isFake: true }
          ];
          
      if (!skipStateUpdate) setPredictions(results);
      
      if (src) {
        const newItem = {
          id: Math.random().toString(36).substr(2, 9),
          type,
          src,
          predictions: results,
          timestamp: Date.now()
        };
        
        setHistory(prev => [newItem, ...prev].slice(0, 5));

        if (auth.currentUser) {
          try {
            addDoc(collection(db, 'scans'), {
              userId: auth.currentUser.uid,
              type: newItem.type,
              src: newItem.src,
              predictions: newItem.predictions,
              timestamp: newItem.timestamp
            });
          } catch (error) {
            console.error("Error saving to Firestore:", error);
          }
        }
      }
      return results;
    } catch (error) {
      console.error("Classification error:", error);
      return null;
    } finally {
      if (!skipStateUpdate) setIsClassifying(false);
    }
  };

  const triggerFileInput = () => {
    setCameraError(null);
    fileInputRef.current?.click();
  };

  const startLiveCamera = async () => {
    setCameraError(null);
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
      streamRef.current = stream;
      setIsLiveStream(true);
    } catch (err: any) {
      console.error("Error accessing camera:", err);
      let msg = "Could not access camera.";
      if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
        msg = "Camera permission was denied. Please allow camera access in your browser settings.";
      } else if (err.name === 'NotFoundError' || err.name === 'DevicesNotFoundError') {
        msg = "No camera device found on this system.";
      } else {
        msg = err.message || "Could not access camera. Please make sure permissions are granted.";
      }
      setCameraError(msg);
    }
  };

  const stopLiveCamera = () => {
    if (streamRef.current) {
      streamRef.current.getTracks().forEach(track => track.stop());
      streamRef.current = null;
    }
    setIsLiveStream(false);
  };

  const captureFromLiveCamera = () => {
    if (liveVideoRef.current && canvasRef.current) {
      const video = liveVideoRef.current;
      const canvas = canvasRef.current;
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      const ctx = canvas.getContext('2d');
      if (ctx) {
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        const dataUrl = canvas.toDataURL('image/jpeg');
        stopLiveCamera();
        setMediaSrc(dataUrl);
        setMediaType('image');
        setIsClassifying(true);
        classifyMedia('image', dataUrl);
      }
    }
  };

  const analyzeWithGemini = async () => {
    if (!mediaSrc || mediaType !== 'image') return;
    setIsAnalyzingGemini(true);
    setGeminiAnalysis(null);
    try {
      const response = await fetch('/api/analyze-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          imageBase64: mediaSrc.split(',')[1],
          mimeType: 'image/jpeg', // Best guess or we can parse from data URL
          prompt: "Please analyze this image for signs of deepfake manipulation or AI generation. What details stand out? Give a detailed reasoning."
        })
      });
      const data = await response.json();
      if (data.error) throw new Error(data.error);
      setGeminiAnalysis(data.text);
    } catch (err: any) {
      console.error(err);
      setGeminiAnalysis("Failed to analyze image with Gemini. Please try again.");
    } finally {
      setIsAnalyzingGemini(false);
    }
  };

  const generatePDF = () => {
    const doc = new jsPDF();
    doc.setFontSize(20);
    doc.text('Deepfake Analysis Report', 20, 20);
    doc.setFontSize(12);
    doc.text(`Date: ${new Date().toLocaleString()}`, 20, 30);
    
    doc.text('Results:', 20, 45);
    predictions.forEach((pred, idx) => {
      doc.text(`${pred.className}: ${(pred.probability * 100).toFixed(1)}%`, 20, 55 + (idx * 10));
    });
    
    doc.save('deepfake-analysis-report.pdf');
  };

  return (
    <div className="w-full max-w-xl mx-auto flex flex-col gap-6 pb-20">
      
      {/* Model Status Card */}
      <div className="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 flex items-center justify-between shadow-lg">
        <div className="flex items-center gap-3">
          <div className={`w-2 h-2 rounded-full ${isModelLoading ? 'bg-amber-400 animate-pulse' : modelError ? 'bg-rose-500' : 'bg-emerald-400 animate-pulse'}`} />
          <span className="text-xs font-bold uppercase tracking-widest text-white/60">
            {isModelLoading ? (t.MODEL_LOADING || 'Loading Deepfake Model...') : modelError ? (t.MODEL_ERROR || 'Model Error') : (t.MODEL_READY || 'Model Ready')}
          </span>
        </div>
        <div className="flex items-center gap-4">
          {isModelLoading && <Loader2 className="w-4 h-4 text-white/40 animate-spin" />}
          {modelError && <AlertCircle className="w-4 h-4 text-rose-400" />}
          <button onClick={() => setShowPrivacyModal(true)} className="flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest text-white/30 hover:text-white/60 transition-colors">
            <Shield className="w-3 h-3 text-emerald-400" /> {t.PRIVACY_SETTINGS || 'Privacy'}
          </button>
          <button onClick={() => setShowFeedbackModal(true)} className="flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest text-white/30 hover:text-white/60 transition-colors">
            <MessageSquare className="w-3 h-3" /> {t.FEEDBACK_BUTTON || 'Feedback'}
          </button>
        </div>
      </div>

      {/* Main Image Area */}
      <div className="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden relative shadow-2xl transition-all duration-300 group">
        
        <input 
          type="file"
          accept="image/*,video/*"
          capture="environment"
          multiple
          ref={fileInputRef}
          onChange={handleMediaUpload}
          className="hidden"
        />

        <div className="aspect-[4/5] sm:aspect-[4/3] w-full relative flex flex-col items-center justify-center">
          <div className="absolute inset-0 border-2 border-dashed border-rose-500/20 m-4 rounded-[2rem] pointer-events-none"></div>
          <canvas ref={canvasRef} className="hidden" />

          {mediaSrc || isProcessingBatch ? (
            <div className="relative w-full h-full p-8 flex items-center justify-center">
              {mediaSrc && (mediaType === 'video' ? (
                <video 
                  src={mediaSrc} 
                  autoPlay
                  loop
                  muted
                  playsInline
                  crossOrigin="anonymous"
                  className={`max-w-full max-h-[60vh] rounded-2xl shadow-2xl transition-opacity duration-300 ${isClassifying ? 'opacity-50' : 'opacity-100'} object-contain z-10`}
                />
              ) : (
                <img 
                  src={mediaSrc} 
                  alt="Upload preview" 
                  crossOrigin="anonymous"
                  className={`max-w-full max-h-[60vh] rounded-2xl shadow-2xl transition-opacity duration-300 ${isClassifying ? 'opacity-50' : 'opacity-100'} object-contain z-10`}
                />
              ))}
              
              {(isClassifying || isProcessingBatch) && (
                <div className="absolute inset-0 flex flex-col items-center justify-center z-20">
                  <Loader2 className="w-10 h-10 text-rose-400 animate-spin mb-4 drop-shadow-[0_0_10px_rgba(244,63,94,0.5)]" />
                  <span className="text-xs font-bold text-white tracking-widest uppercase drop-shadow-md">
                    {isProcessingBatch ? (t.PROCESSING_BATCH || 'Processing Batch...') : (t.SCANNING_ARTIFACTS || 'Scanning Artifacts...')}
                  </span>
                  <div className="absolute top-1/2 left-0 w-full h-[2px] bg-rose-400/50 shadow-[0_0_15px_rgba(244,63,94,0.8)] animate-pulse"></div>
                </div>
              )}

              <div className="absolute bottom-6 right-6 z-30 flex gap-2">
                <button 
                  onClick={() => {
                    setMediaSrc(null);
                    setPredictions([]);
                    setUrlInput('');
                  }}
                  disabled={isModelLoading || isClassifying || isProcessingBatch}
                  className="bg-black/40 hover:bg-black/60 backdrop-blur-md border border-white/20 text-white p-3 rounded-full shadow-lg transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2"
                >
                  <Camera className="w-5 h-5" />
                </button>
              </div>
            </div>
          ) : (
            <div className="flex flex-col items-center justify-center p-8 w-full max-w-sm relative z-10">
              <div className="w-20 h-20 bg-slate-800 rounded-2xl border border-white/20 flex items-center justify-center mb-6 shadow-2xl overflow-hidden relative">
                <div className="absolute inset-0 bg-gradient-to-br from-rose-500/20 to-indigo-500/20 flex items-center justify-center">
                  <Video className="w-10 h-10 text-white/20" />
                </div>
              </div>
              <h3 className="text-2xl font-semibold text-white mb-2 tracking-tight text-center">{t.ANALYZE_MEDIA || 'Analyze Media'}</h3>
              <p className="text-white/40 text-sm mb-8 text-center">
                {t.CHOOSE_MEDIA_TXT || 'Upload a file, batch of files, or paste a link to scan for AI manipulation.'}
              </p>
              
              <div className="flex flex-col sm:flex-row w-full gap-4 mb-6">
                <button 
                  onClick={triggerFileInput}
                  disabled={isModelLoading}
                  className="flex-1 px-6 py-3 bg-white text-slate-950 font-bold rounded-xl hover:bg-rose-400 hover:text-slate-950 transition-colors flex items-center justify-center gap-2 shadow-lg shadow-white/5 disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] text-sm"
                >
                  <Upload className="w-5 h-5" />
                  {t.UPLOAD_MEDIA || 'Upload Media'}
                </button>
              </div>

              <div className="w-full relative flex items-center py-2 mb-4">
                <div className="flex-grow border-t border-white/10"></div>
                <span className="flex-shrink-0 mx-4 text-white/30 text-xs font-bold uppercase tracking-widest">{t.OR || 'or'}</span>
                <div className="flex-grow border-t border-white/10"></div>
              </div>

              <div className="flex flex-col w-full gap-3">
                <div className="relative">
                  <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <LinkIcon className="h-5 w-5 text-white/30" />
                  </div>
                  <input 
                    type="url" 
                    placeholder={t.URL_PLACEHOLDER || 'Paste image/video URL...'} 
                    value={urlInput}
                    onChange={(e) => setUrlInput(e.target.value)}
                    onKeyDown={(e) => {
                      if (e.key === 'Enter') handleUrlSubmit();
                    }}
                    className="w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-rose-400 focus:ring-1 focus:ring-rose-400 transition-all"
                  />
                </div>
                <button 
                  onClick={handleUrlSubmit}
                  disabled={isModelLoading || !urlInput.trim()}
                  className="w-full px-6 py-3 bg-indigo-500/20 text-indigo-300 border border-indigo-500/30 hover:bg-indigo-500/30 font-bold rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed active:scale-[0.98] text-sm"
                >
                  {t.ANALYZE_URL || 'Analyze URL'}
                </button>
              </div>

            </div>
          )}
        </div>
      </div>

      {/* Results Panel */}
      {predictions.length > 0 && !isClassifying && !isProcessingBatch && (
        <div className="bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 flex flex-col animate-in fade-in slide-in-from-bottom-4 duration-500 shadow-xl">
          <div className="p-6 border-b border-white/10 flex justify-between items-center">
            <div>
              <h2 className="text-lg font-bold text-white mb-1">{t.AUTHENTICITY_ANALYSIS || 'Authenticity Analysis'}</h2>
              <p className="text-xs text-white/40 tracking-tight">{t.CONFIDENCE_SCORES || 'Confidence scores for deepfake detection'}</p>
            </div>
            <button 
              onClick={generatePDF}
              className="flex items-center gap-2 text-xs font-bold text-emerald-400 bg-emerald-400/10 hover:bg-emerald-400/20 px-3 py-2 rounded-lg transition-colors border border-emerald-400/20 uppercase tracking-widest"
            >
              <Download className="w-4 h-4" /> {t.EXPORT_REPORT || 'Export Report'}
            </button>
          </div>
          
          <div className="p-6 space-y-6">
            {predictions.map((pred, idx) => {
              const confidence = (pred.probability * 100).toFixed(1);
              const isTop = idx === 0;
              const textColor = isTop ? (pred.isFake ? 'text-rose-400' : 'text-emerald-400') : 'text-white';
              const barColor = pred.isFake ? 'bg-rose-500' : 'bg-emerald-500';

              return (
                <div key={idx} className="space-y-2">
                  <div className={`flex justify-between items-end ${isTop ? '' : 'opacity-60'}`}>
                    <span className="text-sm font-medium text-white capitalize">
                      {getTranslatedClassName(pred.className)}
                    </span>
                    <span className={`text-sm font-bold ${isTop ? 'text-lg' : ''} ${textColor}`}>{confidence}%</span>
                  </div>
                  
                  {/* Progress Bar */}
                  <div className="h-2 w-full bg-white/10 rounded-full overflow-hidden">
                    <div 
                      className={`h-full rounded-full transition-all duration-1000 ease-out ${isTop ? barColor : 'bg-white/30'}`}
                      style={{ width: `${confidence}%`, transitionDelay: `${idx * 150}ms` }}
                    />
                  </div>
                </div>
              );
            })}
            
            {/* Confidence Chart */}
            <div className="h-40 w-full mt-6 pt-4 border-t border-white/5">
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={predictions} layout="vertical" margin={{ top: 5, right: 30, left: 20, bottom: 5 }}>
                  <XAxis type="number" hide domain={[0, 1]} />
                  <YAxis dataKey="className" type="category" hide />
                  <Tooltip 
                    cursor={{fill: 'rgba(255,255,255,0.05)'}}
                    contentStyle={{ backgroundColor: 'rgba(15, 23, 42, 0.9)', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '8px', color: '#fff', fontSize: '12px' }}
                    itemStyle={{ color: '#fff' }}
                    formatter={(value: number, name: any, props: any) => [`${(value * 100).toFixed(1)}%`, t.CONFIDENCE || 'Confidence']}
                  />
                  <Bar dataKey="probability" radius={[0, 4, 4, 0]} barSize={20}>
                    {predictions.map((entry, index) => (
                      <Cell key={`cell-${index}`} fill={entry.isFake ? '#f43f5e' : '#10b981'} />
                    ))}
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
              <p className="text-center text-[10px] text-white/30 uppercase tracking-widest mt-2 font-bold">{t.PROBABILITY_DIST || 'Probability Distribution'}</p>
            </div>

            {/* Gemini Deep Analysis */}
            {mediaType === 'image' && (
              <div className="mt-8 pt-6 border-t border-white/10">
                <div className="flex items-center justify-between mb-4">
                  <h3 className="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-2">
                    <Sparkles className="w-4 h-4 text-indigo-400" /> Deep Analysis
                  </h3>
                  {!geminiAnalysis && !isAnalyzingGemini && (
                    <button 
                      onClick={analyzeWithGemini}
                      className="px-4 py-2 bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-300 font-bold rounded-lg text-xs transition-colors flex items-center gap-2 uppercase tracking-widest"
                    >
                      Ask Gemini
                    </button>
                  )}
                </div>
                
                {isAnalyzingGemini && (
                  <div className="flex flex-col items-center justify-center p-6 bg-white/5 rounded-xl border border-white/5">
                    <Loader2 className="w-6 h-6 text-indigo-400 animate-spin mb-3" />
                    <p className="text-xs text-white/60 font-bold uppercase tracking-widest animate-pulse">Analyzing image details...</p>
                  </div>
                )}

                {geminiAnalysis && (
                  <div className="bg-white/5 rounded-xl border border-white/10 p-5 text-sm text-white/80 leading-relaxed whitespace-pre-wrap">
                    {geminiAnalysis}
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      )}

      {/* History Toggle */}
      {history.length > 0 && (
        <div className="flex justify-between items-center px-2 mt-4 border-t border-white/10 pt-6">
          <h3 className="text-sm font-bold text-white uppercase tracking-widest flex items-center gap-2">
            <History className="w-4 h-4 text-indigo-400" /> {t.RECENT_SCANS || 'Recent Scans'}
          </h3>
          <button 
            onClick={() => setShowHistory(!showHistory)}
            className="text-xs font-bold text-white/40 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-1"
          >
            <List className="w-3 h-3" />
            {showHistory ? (t.HIDE || 'Hide') : (t.SHOW || 'Show')}
          </button>
        </div>
      )}

      {/* History List */}
      {showHistory && history.length > 0 && (
        <div className="space-y-3 animate-in fade-in slide-in-from-top-2 duration-300">
          {history.map(item => (
            <div 
              key={item.id} 
              onClick={() => {
                setMediaSrc(item.src);
                setMediaType(item.type);
                setPredictions(item.predictions);
                window.scrollTo({ top: 0, behavior: 'smooth' });
              }}
              className="bg-white/5 backdrop-blur-md border border-white/5 rounded-xl p-3 flex gap-4 items-center shadow-lg hover:bg-white/10 transition-colors cursor-pointer group"
            >
              <div className="w-16 h-16 rounded-lg overflow-hidden shrink-0 bg-slate-800 border border-white/10 relative">
                <div className="absolute inset-0 bg-emerald-400/20 opacity-0 group-hover:opacity-100 transition-opacity z-10 flex items-center justify-center">
                  <span className="text-[10px] font-bold text-emerald-300 uppercase tracking-widest">View</span>
                </div>
                {item.type === 'video' && !item.src.startsWith('data:') ? (
                   <video src={item.src} className="w-full h-full object-cover opacity-80" />
                ) : (
                   <img src={item.src} className="w-full h-full object-cover opacity-80" />
                )}
              </div>
              <div className="flex-1">
                <p className="text-sm font-medium text-white">
                  {getTranslatedClassName(item.predictions[0].className)}
                </p>
                <p className={`text-xs font-bold ${item.predictions[0].isFake ? 'text-rose-400' : 'text-emerald-400'}`}>
                  {(item.predictions[0].probability * 100).toFixed(1)}% {t.CONFIDENCE || 'Confidence'}
                </p>
                <p className="text-[10px] text-white/30 mt-1 uppercase tracking-widest font-bold">
                  {new Date(item.timestamp).toLocaleTimeString()}
                </p>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Feedback Modal */}
      {showFeedbackModal && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm animate-in fade-in duration-200">
          <div className="bg-slate-900 border border-white/10 rounded-2xl w-full max-w-md shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-200">
            <div className="flex items-center justify-between p-4 border-b border-white/10 bg-white/5">
              <h3 className="font-bold text-white tracking-tight flex items-center gap-2">
                <MessageSquare className="w-4 h-4 text-emerald-400" />
                {t.FEEDBACK_TITLE || 'Provide Feedback'}
              </h3>
              <button 
                onClick={() => setShowFeedbackModal(false)}
                className="p-1 rounded-lg text-white/40 hover:text-white hover:bg-white/10 transition-colors"
              >
                <X className="w-5 h-5" />
              </button>
            </div>
            
            <div className="p-5 flex flex-col gap-4">
              <textarea
                value={feedbackText}
                onChange={(e) => setFeedbackText(e.target.value)}
                placeholder={t.FEEDBACK_PLACEHOLDER || 'Tell us about your experience...'}
                className="w-full h-32 bg-white/5 border border-white/10 rounded-xl p-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/50 resize-none transition-all"
              />
              
              <div className="flex justify-end gap-3 pt-2">
                <button 
                  onClick={() => setShowFeedbackModal(false)}
                  className="px-4 py-2 rounded-lg text-xs font-bold text-white/50 hover:text-white hover:bg-white/5 transition-colors uppercase tracking-widest"
                >
                  {t.CANCEL || 'Cancel'}
                </button>
                <button 
                  onClick={() => {
                    alert(t.FEEDBACK_SUBMITTED || "Thank you for your feedback!");
                    setShowFeedbackModal(false);
                    setFeedbackText('');
                  }}
                  disabled={!feedbackText.trim()}
                  className="px-5 py-2 rounded-lg text-xs font-bold bg-emerald-500 hover:bg-emerald-400 text-slate-950 transition-colors uppercase tracking-widest disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  {t.SUBMIT || 'Submit'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Privacy Settings Modal */}
      {showPrivacyModal && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm animate-in fade-in duration-200">
          <div className="bg-slate-900 border border-white/10 rounded-2xl w-full max-w-md shadow-2xl overflow-hidden flex flex-col animate-in zoom-in-95 duration-200">
            <div className="flex items-center justify-between p-4 border-b border-white/10 bg-white/5">
              <h3 className="font-bold text-white tracking-tight flex items-center gap-2">
                <Shield className="w-4 h-4 text-emerald-400" />
                {t.PRIVACY_SETTINGS || 'Privacy Settings'}
              </h3>
              <button 
                onClick={() => setShowPrivacyModal(false)}
                className="p-1 rounded-lg text-white/40 hover:text-white hover:bg-white/10 transition-colors"
              >
                <X className="w-5 h-5" />
              </button>
            </div>
            
            <div className="p-5 flex flex-col gap-6">
              {/* Storage Mode Toggles */}
              <div className="space-y-3">
                <label className="text-xs font-bold text-white/40 uppercase tracking-widest block">
                  {t.STORAGE_MODE || 'Storage Mode'}
                </label>
                
                <div className="flex flex-col gap-3">
                  <button 
                    onClick={() => setStorageMode('local')}
                    className={`p-4 rounded-xl border text-left flex gap-3 transition-all ${storageMode === 'local' ? 'bg-indigo-500/15 border-indigo-500/50' : 'bg-white/5 border-white/10 hover:bg-white/10'}`}
                  >
                    <div className={`w-4 h-4 rounded-full border-2 flex items-center justify-center shrink-0 mt-0.5 ${storageMode === 'local' ? 'border-indigo-400' : 'border-white/30'}`}>
                      {storageMode === 'local' && <div className="w-2 h-2 bg-indigo-400 rounded-full" />}
                    </div>
                    <div>
                      <h4 className="text-sm font-bold text-white">{t.STORE_LOCALLY || 'Persistent Local Storage'}</h4>
                      <p className="text-xs text-white/50 mt-1">{t.STORE_LOCALLY_DESC || "Keep analysis history saved in your browser's local storage between sessions."}</p>
                    </div>
                  </button>

                  <button 
                    onClick={() => setStorageMode('session')}
                    className={`p-4 rounded-xl border text-left flex gap-3 transition-all ${storageMode === 'session' ? 'bg-indigo-500/15 border-indigo-500/50' : 'bg-white/5 border-white/10 hover:bg-white/10'}`}
                  >
                    <div className={`w-4 h-4 rounded-full border-2 flex items-center justify-center shrink-0 mt-0.5 ${storageMode === 'session' ? 'border-indigo-400' : 'border-white/30'}`}>
                      {storageMode === 'session' && <div className="w-2 h-2 bg-indigo-400 rounded-full" />}
                    </div>
                    <div>
                      <h4 className="text-sm font-bold text-white">{t.CLEAR_SESSION || 'Session Only (Clear on exit)'}</h4>
                      <p className="text-xs text-white/50 mt-1">{t.CLEAR_SESSION_DESC || "Keep history only in temporary memory. It will be wiped when you refresh or close this tab."}</p>
                    </div>
                  </button>
                </div>
              </div>

              {/* Clear History Button */}
              {history.length > 0 && (
                <div className="pt-2">
                  <button 
                    onClick={async () => {
                      if (confirm(t.CONFIRM_CLEAR_HISTORY || "Are you sure you want to clear your analysis history?")) {
                        setHistory([]);
                        localStorage.removeItem('analysisHistory');
                        sessionStorage.removeItem('analysisHistory');
                        
                        if (auth.currentUser) {
                          try {
                            const q = query(collection(db, 'scans'), where('userId', '==', auth.currentUser.uid));
                            const querySnapshot = await getDocs(q);
                            const batch = writeBatch(db);
                            querySnapshot.forEach((document) => {
                              batch.delete(document.ref);
                            });
                            await batch.commit();
                          } catch (error) {
                            console.error("Error clearing history from Firestore", error);
                          }
                        }
                        
                        alert(t.HISTORY_CLEARED || "Local history cleared successfully.");
                      }
                    }}
                    className="w-full py-2.5 px-4 bg-rose-500/10 border border-rose-500/20 hover:bg-rose-500/20 text-rose-400 rounded-xl font-bold text-xs flex items-center justify-center gap-2 transition-colors uppercase tracking-widest"
                  >
                    <Trash2 className="w-4 h-4" />
                    {t.CLEAR_HISTORY_NOW || 'Clear History'}
                  </button>
                </div>
              )}

              {/* Security Banner */}
              <div className="p-4 bg-emerald-500/5 border border-emerald-500/10 rounded-xl flex gap-3">
                <Shield className="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" />
                <div>
                  <h4 className="text-xs font-bold text-emerald-400 uppercase tracking-wider">
                    {t.PRIVACY_NOTICE || 'On-Device Privacy Guard'}
                  </h4>
                  <p className="text-[11px] text-white/55 mt-1 leading-relaxed">
                    {t.PRIVACY_NOTICE_DESC || 'All detection scans run purely in your browser. Your images and videos are never sent to external servers.'}
                  </p>
                </div>
              </div>

              <div className="flex justify-end gap-3 pt-2 border-t border-white/5">
                <button 
                  onClick={() => setShowPrivacyModal(false)}
                  className="px-5 py-2.5 bg-white text-slate-950 hover:bg-rose-400 hover:text-slate-950 font-bold rounded-xl transition-all active:scale-[0.98] text-xs uppercase tracking-widest"
                >
                  {t.SUBMIT || 'Done'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

    </div>
  );
}
